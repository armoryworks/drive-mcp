# Override the default credentials/tokens directory.
# Default: ~/.armoryworks/drive-mcp/
# ARMORYWORKS_DRIVE_MCP_HOME=/custom/path

# Override the OAuth redirect listener port for the auth flow.
# Default: 8765
# ARMORYWORKS_DRIVE_MCP_OAUTH_PORT=8765

# Override log level. One of: silent, error, warn, info, debug.
# Default: info
# ARMORYWORKS_DRIVE_MCP_LOG_LEVEL=info
